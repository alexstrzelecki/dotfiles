{{- $macHostType := get . "mac_host_type" | default "personal" -}}
{{- $linuxHostType := get . "linux_host_type" | default "server" -}}
[ -f "$HOME/.local/bin/env" ] && . "$HOME/.local/bin/env"

[ -f "$HOME/.lcldevrc" ] && . "$HOME/.lcldevrc"

[ -f "$HOME/.atuin/bin/env" ] && . "$HOME/.atuin/bin/env"

alias gs="git status"
alias dps="docker ps"
alias la="ls -A"
alias ll='ls -lah'
alias l='ls -CF'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias ~='cd ~'
alias mkdir='mkdir -pv'
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -i'

{{ if eq .chezmoi.os "darwin" -}}
alias ls='ls -G'
alias df='df -h'
alias topdisk='du -hd 1 | sort -hr | head -20'
{{ else if eq .chezmoi.os "linux" -}}
alias df='df -hT'
alias free='free -h'
alias topdisk='du -h --max-depth=1 | sort -rh | head -20'
{{- end }}

if ! command -v starship &>/dev/null; then
_prompt_pwd() {
  local path="${PWD/#$HOME/\~}"
  local depth
  depth=$(tr -cd '/' <<< "$path" | wc -c)
  if (( depth <= 6 )); then
    printf '%s' "$path"
  else
    local last3
    last3=$(sed 's|.*/\([^/]*/[^/]*/[^/]*\)$|\1|' <<< "$path")
    local prefix
    if [[ "$path" == "~"* ]]; then
      prefix="~"
    else
      prefix="/$(cut -d'/' -f2 <<< "$path")"
    fi
    printf '%s' "${prefix}/.../${last3}"
  fi
}

PS1='$(_prompt_pwd) \$ '
fi

[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

[ -f "$HOME/.fzf.bash" ] && . "$HOME/.fzf.bash"

if command -v mise &>/dev/null; then
  eval "$(mise activate bash)"
fi

{{ if or (and (eq .chezmoi.os "darwin") (eq $macHostType "personal")) (and (eq .chezmoi.os "linux") (eq $linuxHostType "workstation")) -}}
if [ -d "$HOME/.bun" ]; then
  export BUN_INSTALL="$HOME/.bun"
  case ":$PATH:" in
    *:"$BUN_INSTALL/bin":*) ;;
    *) export PATH="$BUN_INSTALL/bin:$PATH" ;;
  esac
fi
{{- end }}

{{ if and (eq .chezmoi.os "darwin") (eq $macHostType "personal") -}}
if [ -d "$HOME/.lmstudio/bin" ]; then
  case ":$PATH:" in
    *:"$HOME/.lmstudio/bin":*) ;;
    *) export PATH="$PATH:$HOME/.lmstudio/bin" ;;
  esac
fi
{{- end }}

[[ -f ~/.bashrc.bbg ]] && source ~/.bashrc.bbg

if command -v starship &>/dev/null; then
  eval "$(starship init bash)"
fi

# Shell integrations last — nothing after this should touch PROMPT_COMMAND or the DEBUG trap
if command -v atuin &>/dev/null && [ -f "$HOME/.bash-preexec.sh" ]; then
  source ~/.bash-preexec.sh
  eval "$(atuin init bash)"
fi
